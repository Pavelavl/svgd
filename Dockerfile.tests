# Test runner image for CI
FROM debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    # Build dependencies
    gcc make librrd-dev libduktape-dev jq git \
    # Test dependencies
    golang-go python3 python3-venv python3-pip \
    # System utilities for tests
    lsof flock curl procps \
    && rm -rf /var/lib/apt/lists/*

# Go environment
ENV GOPATH=/go
ENV PATH=$PATH:/go/bin
ENV CGO_ENABLED=1

WORKDIR /app

# Copy project files
COPY . .

# Build binaries
RUN make build

# Build test utilities
RUN make build-tests

# Install Python dependencies for UI tests
RUN python3 -m venv .venv && \
    .venv/bin/pip install -r tests/ui/requirements.txt

CMD ["make", "test"]
