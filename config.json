{
	"server": {
		"tcp_port": 8081,
		"protocol": "lsrp",
		"allowed_ips": "127.0.0.1",
		"rrdcached_addr": "",
		"thread_pool_size": 4,
		"cache_ttl_seconds": 5,
		"verbose": 0
	},
	"rrd": {
		"base_path": "/opt/collectd/var/lib/collectd/rrd/localhost"
	},
	"js": {
		"script_path": "./scripts/generate_svg.js"
	},
	"metrics": [
		{
			"endpoint": "cpu",
			"rrd_path": "cpu-total/percent-active.rrd",
			"requires_param": false,
			"title": "CPU Utilization",
			"y_label": "Usage (%)",
			"is_percentage": true,
			"value_format": "%.1f"
		},
		{
			"endpoint": "cpu/process",
			"rrd_path": "processes-%s/ps_cputime.rrd",
			"requires_param": true,
			"title": "CPU Time",
			"y_label": "CPU Time (seconds)",
			"is_percentage": false,
			"value_format": "%.2f",
			"param_name": "process_name",
			"transform_type": "sum"
		},
		{
			"endpoint": "ram",
			"rrd_path": "memory/percent-used.rrd",
			"requires_param": false,
			"title": "RAM Utilization",
			"y_label": "Usage (%)",
			"is_percentage": true,
			"value_format": "%.1f"
		},
		{
			"endpoint": "ram/process",
			"rrd_path": "processes-%s/ps_rss.rrd",
			"requires_param": true,
			"title": "Memory Usage",
			"y_label": "Memory (MB)",
			"is_percentage": false,
			"value_format": "%.1f",
			"param_name": "process_name",
			"transform_type": "divide",
			"transform_divisor": 1048576
		},
		{
			"endpoint": "network",
			"rrd_path": "interface-%s/if_octets.rrd",
			"requires_param": true,
			"title": "Network Traffic",
			"y_label": "Traffic (Mbit/s)",
			"is_percentage": false,
			"value_format": "%.2f",
			"param_name": "interface",
			"transform_type": "divide",
			"transform_divisor": 125000
		},
		{
			"endpoint": "disk",
			"rrd_path": "disk-%s/disk_ops.rrd",
			"requires_param": true,
			"title": "Disk Operations",
			"y_label": "Operations/s",
			"is_percentage": false,
			"value_format": "%.1f",
			"param_name": "disk"
		},
		{
			"endpoint": "postgresql/connections",
			"rrd_path": "postgresql-test/pg_numbackends.rrd",
			"requires_param": false,
			"title": "PostgreSQL Connections",
			"y_label": "Connections",
			"is_percentage": false,
			"value_format": "%d"
		},
		{
			"endpoint": "system/load",
			"rrd_path": "load/load.rrd",
			"requires_param": false,
			"title": "System Load Average",
			"y_label": "Load",
			"is_percentage": false,
			"value_format": "%.2f"
		},
		{
			"endpoint": "system/uptime",
			"rrd_path": "uptime/uptime.rrd",
			"requires_param": false,
			"title": "System Uptime",
			"y_label": "hours",
			"is_percentage": false,
			"value_format": "%.1f",
			"transform_type": "divide",
			"transform_divisor": 3600
		},
		{
			"endpoint": "swap/bytes",
			"rrd_path": "swap/swap-used.rrd",
			"requires_param": false,
			"title": "Swap Usage (Bytes)",
			"y_label": "Memory (MB)",
			"is_percentage": false,
			"value_format": "%.1f",
			"transform_type": "divide",
			"transform_divisor": 1048576
		},
		{
			"endpoint": "filesystem",
			"rrd_path": "df-%s/df_complex-used.rrd",
			"requires_param": true,
			"title": "Filesystem Usage",
			"y_label": "Usage (GB)",
			"is_percentage": false,
			"value_format": "%.2f",
			"param_name": "mount_point",
			"transform_type": "divide",
			"transform_divisor": 1073741824
		},
		{
			"endpoint": "filesystem/free",
			"rrd_path": "df-%s/df_complex-free.rrd",
			"requires_param": true,
			"title": "Filesystem Free Space",
			"y_label": "Free (GB)",
			"is_percentage": false,
			"value_format": "%.2f",
			"param_name": "mount_point",
			"transform_type": "divide",
			"transform_divisor": 1073741824
		},
		{
			"endpoint": "ram/cached",
			"rrd_path": "memory/percent-cached.rrd",
			"requires_param": false,
			"title": "Cached Memory",
			"y_label": "Usage (%)",
			"is_percentage": true,
			"value_format": "%.1f"
		},
		{
			"endpoint": "ram/buffered",
			"rrd_path": "memory/percent-buffered.rrd",
			"requires_param": false,
			"title": "Buffered Memory",
			"y_label": "Usage (%)",
			"is_percentage": true,
			"value_format": "%.1f"
		},
		{
			"endpoint": "swap/percent",
			"rrd_path": "swap/swap_percent-used.rrd",
			"requires_param": false,
			"title": "Swap Utilization",
			"y_label": "Usage (%)",
			"is_percentage": true,
			"value_format": "%.1f"
		},
		{
			"endpoint": "disk/throughput",
			"rrd_path": "disk-%s/disk_octets.rrd",
			"requires_param": true,
			"title": "Disk Throughput",
			"y_label": "Throughput (MB/s)",
			"is_percentage": false,
			"value_format": "%.2f",
			"param_name": "disk",
			"transform_type": "divide",
			"transform_divisor": 1048576
		},
		{
			"endpoint": "disk/io_time",
			"rrd_path": "disk-%s/disk_time.rrd",
			"requires_param": true,
			"title": "Disk I/O Time",
			"y_label": "IO Time (ms)",
			"is_percentage": false,
			"value_format": "%.1f",
			"param_name": "disk"
		},
		{
			"endpoint": "network/packets",
			"rrd_path": "interface-%s/if_packets.rrd",
			"requires_param": true,
			"title": "Network Packets",
			"y_label": "Packets/s",
			"is_percentage": false,
			"value_format": "%.1f",
			"param_name": "interface"
		},
		{
			"endpoint": "network/errors",
			"rrd_path": "interface-%s/if_errors.rrd",
			"requires_param": true,
			"title": "Network Errors",
			"y_label": "Errors/s",
			"is_percentage": false,
			"value_format": "%.1f",
			"param_name": "interface"
		},
		{
			"endpoint": "process/count",
			"rrd_path": "processes-%s/ps_count.rrd",
			"requires_param": true,
			"title": "Process Count",
			"y_label": "Processes",
			"is_percentage": false,
			"value_format": "%d",
			"param_name": "process_name"
		},
		{
			"endpoint": "tcp/connections",
			"rrd_path": "tcpconns-80-local/tcp_connections-ESTABLISHED.rrd",
			"requires_param": false,
			"title": "TCP Established Connections",
			"y_label": "Connections",
			"is_percentage": false,
			"value_format": "%d"
		},
		{
			"endpoint": "tcp/time_wait",
			"rrd_path": "tcpconns-80-local/tcp_connections-TIME_WAIT.rrd",
			"requires_param": false,
			"title": "TCP TIME_WAIT Connections",
			"y_label": "Connections",
			"is_percentage": false,
			"value_format": "%d"
		},
		{
			"endpoint": "thermal",
			"rrd_path": "thermal-thermal_zone0/temperature.rrd",
			"requires_param": false,
			"title": "CPU Temperature",
			"y_label": "Temperature (°C)",
			"is_percentage": false,
			"value_format": "%.1f"
		}
	]
}